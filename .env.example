# Supabase project (https://app.supabase.com -> Project Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# Service-role key. Server-only. Used for admin tasks (audit log writes, seed).
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# Direct Postgres connection string (for running seed SQL via psql).
# Found under Project Settings -> Database -> Connection string -> URI.
SUPABASE_DB_URL=postgres://postgres:[PASSWORD]@db.YOUR-PROJECT-REF.supabase.co:5432/postgres

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
